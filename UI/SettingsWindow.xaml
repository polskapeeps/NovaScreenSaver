<Window x:Class="NovaScreenSaver.UI.SettingsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:local="clr-namespace:NovaScreenSaver.UI"
        Title="Nova Screensaver Settings" Height="520" Width="720"
        WindowStartupLocation="CenterScreen">
  <Grid Margin="16">
    <Grid.ColumnDefinitions>
      <ColumnDefinition Width="2*"/>
      <ColumnDefinition Width="3*"/>
    </Grid.ColumnDefinitions>

    <StackPanel Grid.Column="0" Margin="0,0,16,0">
      <TextBlock Text="Style" FontWeight="SemiBold" Margin="0,16,0,4"/>
      <ComboBox x:Name="StyleBox" SelectedIndex="0">
        <ComboBoxItem Content="Aurora"/>
        <ComboBoxItem Content="Orbs"/>
      </ComboBox>

      <TextBlock Text="Palette" FontWeight="SemiBold" Margin="0,16,0,4"/>
      <ComboBox x:Name="PaletteBox" SelectedIndex="0">
        <ComboBoxItem Content="Ocean"/>
        <ComboBoxItem Content="Sunset"/>
        <ComboBoxItem Content="Forest"/>
        <ComboBoxItem Content="Neon"/>
        <ComboBoxItem Content="Monochrome"/>
      </ComboBox>

      <TextBlock Text="Speed" FontWeight="SemiBold" Margin="0,16,0,4"/>
      <Slider x:Name="SpeedSlider" Minimum="0.1" Maximum="3" Value="1" TickFrequency="0.1" IsSnapToTickEnabled="True"/>

      <TextBlock Text="Complexity" FontWeight="SemiBold" Margin="0,16,0,4"/>
      <Slider x:Name="ComplexitySlider" Minimum="1" Maximum="5" Value="2" TickFrequency="1" IsSnapToTickEnabled="True"/>

      <TextBlock Text="Intensity" FontWeight="SemiBold" Margin="0,16,0,4"/>
      <Slider x:Name="IntensitySlider" Minimum="0.5" Maximum="2.0" Value="1.0" TickFrequency="0.1" IsSnapToTickEnabled="True"/>

      <TextBlock Text="Resolution scale" FontWeight="SemiBold" Margin="0,16,0,4"/>
      <Slider x:Name="ScaleSlider" Minimum="0.35" Maximum="1.0" Value="0.75" TickFrequency="0.05" IsSnapToTickEnabled="True"/>

      <CheckBox x:Name="ClockCheck" Content="Show clock" Margin="0,16,0,0"/>
      
      <StackPanel Orientation="Horizontal" Margin="0,24,0,0">
        <Button Content="Save" Width="100" Margin="0,0,12,0" Click="OnSave"/>
        <Button Content="Cancel" Width="100" Click="OnCancel"/>
      </StackPanel>
    </StackPanel>

    <Border Grid.Column="1" Background="Black" CornerRadius="8" Padding="8">
      <Grid>
        <local:PreviewCanvas x:Name="Preview" />
        <TextBlock Text="Preview" Foreground="#AAFFFFFF" HorizontalAlignment="Left" VerticalAlignment="Top" Margin="12" />
      </Grid>
    </Border>
  </Grid>
</Window>
